cmake_minimum_required(VERSION 4.2)
project(UnChat C)

set(CMAKE_C_STANDARD 23)

find_package(PkgConfig REQUIRED)
find_program(BLUEPRINT_COMPILER blueprint-compiler)

file(GLOB BLUEPRINT_FILES *.blp)
foreach(BLP_FILE ${BLUEPRINT_FILES})
    get_filename_component(BASENAME ${BLP_FILE} NAME_WE)
    add_custom_command(
            OUTPUT ${CMAKE_BINARY_DIR}${BASENAME}.ui
            COMMAND ${BLUEPRINT_COMPILER} compile ${BLP_FILE} -o ${CMAKE_BINARY_DIR}${BASENAME}.ui
            DEPENDS ${BLP_FILE}
            COMMENT "Compiling ${BASENAME}.blp"
    )
    list(APPEND UI_FILES ${CMAKE_BINARY_DIR}${BASENAME}.ui)
endforeach()

pkg_check_modules(GTK4 REQUIRED IMPORTED_TARGET
        gtk4>=4.14
        gmodule-export-2.0
)

set(CMAKE_RUNTIME_OUTPUT_DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR})
add_executable(client client.c ${UI_FILES})
add_executable(server server.c)
target_link_libraries(client PRIVATE PkgConfig::GTK4)